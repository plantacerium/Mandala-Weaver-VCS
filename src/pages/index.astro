---
import AppLayout from '../layouts/AppLayout.astro';
import MandalaCanvas from '../components/mandala/MandalaCanvas';
import SidebarHistory from '../components/panels/SidebarHistory';
import SidebarNav from '../components/panels/SidebarNav';
import MonadInspector from '../components/panels/MonadInspector';
import DistillPanel from '../components/panels/DistillPanel';
import TerminalPanel from '../components/panels/TerminalPanel';
import '../styles/components/sidebar.css';
import '../styles/components/workspace.css';
import '../styles/panels/panels.css';
---

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const expandBtn = document.querySelector('.btn-expand');
    if (expandBtn) {
      expandBtn.addEventListener('click', () => {
        if ((window as any).openCommitDialog) {
          (window as any).openCommitDialog();
        }
      });
    }
  });
</script>

<AppLayout title="Mandala Weaver VCS">
	<main>
		<nav class="sidebar">
			<div class="logo">
				<img src="/assets/mandala-icon.png" alt="Mandala" class="logo-img" />
				<span>MANDALA</span>
			</div>
			<SidebarNav client:load />
			
			<SidebarHistory client:load />

			<footer class="sidebar-footer">
				<div class="status">
					<span class="dot"></span>
					<span>Registro Akáshico Online</span>
				</div>
			</footer>
		</nav>

		<section class="workspace">
			<header class="workspace-header">
				<div class="project-info">
					<h1>Untitled_Project</h1>
					<span class="path">~/mandala/default</span>
				</div>
				<div class="actions">
					<button class="btn-expand">EXPAND (Commit)</button>
				</div>
			</header>

			<div class="canvas-wrapper">
				<MandalaCanvas client:only="react" />
				<MonadInspector client:load />
                <DistillPanel client:load />
			</div>
		</section>
		
		<TerminalPanel client:load />
	</main>
</AppLayout>
